# PhishGuard Pro - Environment Configuration
# Copy this file to .env and update the values

# Application Settings
APP_NAME=PhishGuard Pro
APP_VERSION=1.0.0
ENVIRONMENT=demo
DEBUG=true

# Backend Configuration
BACKEND_HOST=localhost
BACKEND_PORT=8000
BACKEND_URL=http://localhost:8000

# Frontend Configuration
FRONTEND_HOST=localhost
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000

# Database Configuration (for demo, using SQLite)
DATABASE_URL=sqlite:///./data/phishguard.db

# JWT Configuration (DEMO KEYS - DO NOT USE IN PRODUCTION)
JWT_SECRET_KEY=demo-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Model Configuration
MODEL_PATH=./data/models
MODEL_VERSION=v1.0.0

# Sandbox Configuration
SANDBOX_TIMEOUT=30
SANDBOX_MEMORY_LIMIT=512

# Playwright Configuration
PLAYWRIGHT_BROWSER_PATH=/usr/bin/chromium-browser
PLAYWRIGHT_HEADLESS=true

# Demo Data Configuration
DEMO_DATA_PATH=./data/demo_campaigns.json
DEMO_MODE=true

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
RATE_LIMIT_PER_MINUTE=100

# Extension Configuration
EXTENSION_ID=phishguard-pro-extension
EXTENSION_VERSION=1.0.0

# Compliance Settings
PII_MASKING=true
DATA_RETENTION_DAYS=30
TELEMETRY_ENABLED=false